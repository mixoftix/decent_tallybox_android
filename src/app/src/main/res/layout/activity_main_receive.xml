<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center|top"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar_home"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Graph Info -->
        <TextView
            android:id="@+id/textview_graph_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|top"
            android:text="@string/graph_info_placeholder"
            android:textSize="13sp"
            android:textStyle="italic" />

        <!-- Wallet Info -->
        <TextView
            android:id="@+id/textview_privatekey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:padding="10dp"
            android:text="@string/my_wallet"
            android:textSize="17sp" />

        <!-- Wallet Address -->
        <TextView
            android:id="@+id/textview_wallet"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:padding="10dp"
            android:text="@string/wallet_address_placeholder"
            android:drawablePadding="8dp"
            android:drawableEnd="@drawable/baseline_content_copy_24"
            android:textSize="17sp"
            android:background="@drawable/frame_white" />

        <!-- Point of Sale Checkbox -->
        <CheckBox
            android:id="@+id/checkbox_is_pos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:padding="10dp"
            android:text="@string/point_of_sale"
            android:textSize="17sp"
            android:checked="false" />

        <!-- POS Layout -->
        <LinearLayout
            android:id="@+id/layout_of_pos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center|top"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/frame_white"
            android:visibility="gone">

            <!-- Token Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/token_label"
                    android:textSize="16sp"
                    android:paddingEnd="8dp" />

                <LinearLayout
                    android:id="@+id/dropdown_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:padding="10dp"
                    android:background="@drawable/frame_white">

                    <ImageView
                        android:id="@+id/dropdown_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/baseline_fingerprint_24" />

                    <TextView
                        android:id="@+id/dropdown_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:text="@string/select_token"
                        android:textSize="16sp"
                        android:paddingStart="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Amount -->
            <EditText
                android:id="@+id/editTextAmount"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="12dp"
                android:hint="@string/hint_amount"
                android:drawablePadding="8dp"
                android:drawableEnd="@drawable/baseline_dialpad_24"
                android:inputType="numberDecimal" />

            <!-- Order ID -->
            <EditText
                android:id="@+id/editTextOrder"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="12dp"
                android:hint="@string/hint_order_id_optional"
                android:drawablePadding="8dp"
                android:drawableEnd="@drawable/baseline_shopping_cart_24"
                android:inputType="text" />

        </LinearLayout>

        <!-- Generate QR Button -->
        <Button
            android:id="@+id/buttonGenerateQR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="12dp"
            android:drawablePadding="8dp"
            android:drawableEnd="@drawable/baseline_qr_code_2_24"
            android:textStyle="bold"
            android:text="@string/generate_qr_code" />

    </LinearLayout>
</ScrollView>