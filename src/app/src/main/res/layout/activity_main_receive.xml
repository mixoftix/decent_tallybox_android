<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="top"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_gravity="top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center|top"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Menu Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar_home"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Layout Receive -->
        <!-- Graph Info -->
        <TextView
            android:id="@+id/textview_graph_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|top"
            android:padding="0dp"
            android:text="---"
            android:textSize="13sp"
            android:textStyle="italic"
            />

        <!-- Wallet Info -->
        <TextView
            android:id="@+id/textview_privatekey"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:padding="10dp"
            android:text="My wallet:"
            android:textSize="17sp"
            />

        <!-- Wallet Address TextView -->
        <TextView
            android:id="@+id/textview_wallet"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:padding="10dp"
            android:text="---"
            android:drawablePadding="2dp"
            android:drawableRight="@drawable/baseline_content_copy_24"
            android:textSize="17sp"
            android:background="@drawable/frame_white"
            />

        <CheckBox
            android:id="@+id/checkbox_is_pos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:padding="10dp"
            android:text="Point of Sale"
            android:textSize="17sp"
            android:checked="false"
            />

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:id="@+id/layout_of_pos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center|top"
            android:padding="10dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/frame_white"
            android:visibility="gone"
            >

        <!-- Currency -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            >

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Coin:"
            android:textSize="16sp"
            android:paddingEnd="5dp"
            />

        <LinearLayout
            android:id="@+id/dropdown_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:background="@drawable/frame_white"

            >

        <ImageView
            android:id="@+id/dropdown_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/baseline_fingerprint_24"
            android:gravity="center_vertical"
            />

        <TextView
            android:id="@+id/dropdown_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:text="null"
            android:textSize="16sp"
            android:paddingStart="5dp"
            />

        </LinearLayout>
        </LinearLayout>


        <!-- Currency RadioGroup -->
        <!--
        <RadioGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/RadioGroupCurrency">

            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:id="@+id/currency_null"
                android:text="null"/>
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/currency_2zr"
                android:text="2ZR"/>
            <RadioButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/currency_2pn"
                android:text="2PN"/>

        </RadioGroup>
        -->

        <!-- Amount EditText -->
        <EditText
            android:id="@+id/editTextAmount"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:padding="10dp"
            android:hint="Amount"
            android:drawablePadding="2dp"
            android:drawableRight="@drawable/baseline_dialpad_24"
            android:inputType="text" />

        <!-- Order EditText -->
        <EditText
            android:id="@+id/editTextOrder"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:padding="10dp"
            android:hint="Order ID (optional)"
            android:drawablePadding="2dp"
            android:drawableRight="@drawable/baseline_shopping_cart_24"
            android:inputType="text" />

        </LinearLayout>

        <!-- Generate-QR Button -->
        <Button
            android:id="@+id/buttonGenerateQR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:drawablePadding="2dp"
            android:drawableRight="@drawable/baseline_qr_code_2_24"
            android:text="Generate QR Code">
        </Button>

    </LinearLayout>

</ScrollView>