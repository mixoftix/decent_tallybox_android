<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:launchMode="singleTop"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TallyBox"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity_KYC"
            android:exported="false"
            android:label="TallyBox / KYC" />
        <activity
            android:name=".MainActivity_Setting"
            android:exported="false"
            android:label="TallyBox / Setting" />
        <activity
            android:name=".MainActivity_Terms"
            android:exported="false"
            android:label="TallyBox / Terms" />
        <activity
            android:name=".MainActivity_About"
            android:exported="false"
            android:label="TallyBox / About" />
        <activity
            android:name=".MainActivity_History"
            android:exported="false"
            android:label="TallyBox / History" />
        <activity
            android:name=".MainActivity_History_Detail"
            android:exported="false"
            android:label="TallyHash / Detail" />
        <activity
            android:name=".MainActivity_Wallet_config"
            android:exported="false"
            android:label="TallyBox / Config Wallet" />
        <activity
            android:name=".MainActivity_PrivateKey"
            android:exported="false"
            android:label="TallyBox / Private key" />
        <activity
            android:name=".MainActivity_Send"
            android:exported="false"
            android:label="TallyBox / Send" />
        <activity
            android:name=".MainActivity_Send_Scanner"
            android:exported="false"
            android:label="TallyBox / Send-Scan" />
        <activity
            android:name=".MainActivity_Receive"
            android:exported="false"
            android:label="TallyBox / Receive" />
        <activity
            android:name=".MainActivity_Receive_qr"
            android:exported="false"
            android:label="TallyBox / Receive-QR" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="TallyBox">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>