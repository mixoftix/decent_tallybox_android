<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center|top"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar_home"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Graph Info -->
        <TextView
            android:id="@+id/textview_graph_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|top"
            android:text="@string/graph_info_placeholder"
            android:textSize="13sp"
            android:textStyle="italic"
            android:layout_marginBottom="12dp" />

        <!-- To Wallet -->
        <EditText
            android:id="@+id/editTextWalletTo"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="@string/hint_to_wallet"
            android:drawablePadding="8dp"
            android:drawableEnd="@drawable/baseline_account_balance_24"
            android:inputType="text" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/buttonSign"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:drawablePadding="8dp"
                android:drawableEnd="@drawable/baseline_offline_share_24"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="@string/follow_offline_sign" />

            <Button
                android:id="@+id/buttonBroadcast"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:drawablePadding="8dp"
                android:drawableEnd="@drawable/baseline_cloud_upload_24"
                android:enabled="true"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="@string/follow_online_sign" />
        </LinearLayout>

        <!-- Broadcast Progress & Report -->
        <ProgressBar
            android:id="@+id/progressBar2"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:indeterminate="false"
            android:progress="0"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textview_broadcast_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="@string/broadcast_report_placeholder"
            android:textSize="17sp"
            android:background="@drawable/frame_white"
            android:visibility="gone" />

        <!-- Offline Send Layout -->
        <LinearLayout
            android:id="@+id/layout_send_offline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="top|center"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ImageView_offline_SendQR"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginTop="12dp"
                android:contentDescription="@string/qr_code"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textview_offline_send"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:text="@string/offline_raw_transaction_placeholder"
                android:drawablePadding="8dp"
                android:drawableEnd="@drawable/baseline_content_copy_24"
                android:textSize="17sp"
                android:background="@drawable/frame_white"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textview_offline_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:padding="12dp"
                android:text="@string/offline_url_placeholder"
                android:drawablePadding="8dp"
                android:drawableEnd="@drawable/baseline_upload_24"
                android:textSize="17sp"
                android:background="@drawable/frame_white"
                android:visibility="gone"
                android:linksClickable="true" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>