<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="top"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:fillViewport="true">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_gravity="top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center|top"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Menu Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar_language"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Layout Password -->
        <TextView
            android:id="@+id/textview_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:padding="10dp"
            android:text="@string/wallet_password_local"
            android:textSize="17sp"
            />

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center|top"
            android:padding="10dp"
            android:background="@drawable/frame_white"
            >

            <!-- Password1 EditText -->
            <EditText
                android:id="@+id/editTextPassword1"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:padding="10dp"
                android:gravity="left"
                android:textDirection="locale"
                android:layoutDirection="locale"
                android:hint="@string/wallet_password"
                android:drawablePadding="2dp"
                android:drawableEnd="@drawable/baseline_key_24"
                android:inputType="textPassword" />

            <!-- Password2 EditText -->
            <EditText
                android:id="@+id/editTextPassword2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:gravity="left"
                android:padding="10dp"
                android:textDirection="locale"
                android:layoutDirection="locale"
                android:hint="@string/wallet_password_2"
                android:drawablePadding="2dp"
                android:drawableEnd="@drawable/baseline_key_off_24"
                android:inputType="textPassword" />

        </LinearLayout>

        <TextView
            android:id="@+id/textview_restore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:padding="10dp"
            android:text="@string/wallet_type"
            android:textSize="17sp"
            />

        <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center|top"
            android:padding="10dp"
            android:textDirection="locale"
            android:layoutDirection="locale"
            android:layout_marginBottom="10dp"
            android:background="@drawable/frame_white"
            >

            <!-- Wallet type RadioGroup -->
            <RadioGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:id="@+id/RadioGroupWalletAction">

                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:id="@+id/wallet_new"
                    android:text="@string/wallet_new"/>
                <RadioButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/wallet_restore"
                    android:text="@string/wallet_restore"/>

            </RadioGroup>

        <!-- Restore Privatekey EditText -->
        <EditText
            android:id="@+id/editTextRestore_Privatekey"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:padding="10dp"
            android:enabled="false"
            android:visibility="gone"
            android:gravity="left"
            android:textDirection="locale"
            android:layoutDirection="locale"
            android:hint="@string/wallet_private_key"
            android:drawablePadding="2dp"
            android:drawableEnd="@drawable/baseline_lock_24"
            android:inputType="text" />

        </LinearLayout>

        <!-- Generate-QR Button -->
        <Button
            android:id="@+id/buttonPasswordSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:drawablePadding="2dp"
            android:drawableEnd="@drawable/baseline_account_balance_wallet_24"
            android:text="@string/wallet_create">
        </Button>

    </LinearLayout>

</ScrollView>