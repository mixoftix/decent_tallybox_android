<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center|top"
    android:orientation="vertical"
    android:padding="16dp">

        <!-- Toolbar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true">

                <com.google.android.material.appbar.MaterialToolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- Graph / Period Spinner -->
        <Spinner
            android:id="@+id/dropdownSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/frame_white"
            android:textDirection="locale"
            android:layoutDirection="locale"
            android:spinnerMode="dropdown"
            android:textSize="17sp" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

                <!-- Receive Button -->
                <Button
                    android:id="@+id/buttonReceive"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:drawablePadding="6dp"
                    android:drawableEnd="@drawable/baseline_download_24"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:text="@string/receive" />

                <!-- Send Button -->
                <Button
                    android:id="@+id/buttonSend"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:drawablePadding="6dp"
                    android:drawableEnd="@drawable/baseline_upload_24"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:text="@string/send" />
        </LinearLayout>

        <!-- WhatsUp / Status Message -->
        <LinearLayout
            android:id="@+id/layout_main_whatsup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

                <TextView
                    android:id="@+id/textview_main_whatsup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/frame_white"
                    android:text="@string/app_is_up_to_date"
                    android:textSize="17sp" />

        </LinearLayout>

        <!-- Followup layout -->
        <LinearLayout
            android:id="@+id/layout_followup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="visible">

        </LinearLayout>


        <!-- Main Coins / Wallet Layout -->
        <LinearLayout
            android:id="@+id/layout_main_list_of_coins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/frame_white">

                <!-- Last Update -->
                <TextView
                    android:id="@+id/textview_balance_wallet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|bottom"
                    android:paddingBottom="8dp"
                    android:text="@string/last_update"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="12dp"
                    android:background="?attr/colorControlNormal" />

                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/swipeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        </LinearLayout>

        <!-- Advertise Layout -->
        <LinearLayout
            android:id="@+id/layout_main_advertise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

                <TextView
                    android:id="@+id/textview_main_advertise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="12dp"
                    android:background="@drawable/frame_white"
                    android:text="@string/advertise_text"
                    android:textSize="17sp" />
        </LinearLayout>

</LinearLayout>